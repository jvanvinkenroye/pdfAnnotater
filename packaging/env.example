# PDF Annotator – Konfiguration
# Kopieren nach /etc/pdf-annotator/env und Werte anpassen.

# Pflichtfeld: Geheimer Schlüssel für Flask-Sessions (mindestens 32 Zeichen)
# Erzeugen mit: python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=change-me-to-a-random-string

# Optional: Bind-Adresse für Gunicorn (Standard: 0.0.0.0:8000)
#BIND=0.0.0.0:8000

# Optional: Anzahl Gunicorn-Worker (Standard: 4)
#WORKERS=4

# Optional: App-Umgebung (production | development)
APP_ENV=production
